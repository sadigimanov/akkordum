{
  "id": "uzulmedin_mi",
  "title": "Üzülmedin mi?",
  "artist": "Simge Sağın",
  "key": "Em",
  "capo": 0,
  "rhythm": ["↓", "↑", "↑", "↓", "↑", "↑", "↓", "↓","↑"],
  "sections": [
